# ============================================================================
# IPSSI_APOCAL_KIT — Variables d'environnement
# ----------------------------------------------------------------------------
# Copier en .env (gitignored) et adapter selon votre équipe :
#   cp .env.example .env
# ============================================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-en-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
POSTGRES_DB=apocal
POSTGRES_USER=apocal
POSTGRES_PASSWORD=apocal-dev-only
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Ollama ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
# Pour basculer sur un mock (utile pour les tests / dev sans Ollama) :
# LLM_BACKEND=mock        # mock | ollama
LLM_BACKEND=ollama
# Délai max (secondes) d'une génération Ollama. Sur CPU, un modèle 8B met
# souvent 2 à 5 min pour 10 QCM. Augmentez si vos générations échouent en 502
# (timeout) ; réduisez si vous utilisez un modèle léger ou un GPU.
# OLLAMA_TIMEOUT=600

# --- React (Vite) ---
# Note : Vite remplace cette variable au BUILD (ou au démarrage du dev-server),
# PAS au runtime. En dev (npm run dev via docker compose), elle est lue ici.
# Pour un build de production (docker build), passez-la en ARG/ENV au build,
# sinon le bundle figera le fallback http://localhost:8000/api.
VITE_API_BASE_URL=http://localhost:8000/api

# --- Ports hôte (à changer si conflit avec un service local) ---
# Ne décommentez que si docker compose up échoue avec « port already allocated ».
# Le réseau Docker interne reste sur 5432 / 3000.
# POSTGRES_HOST_PORT=5433    # par défaut : 5432
# FRONTEND_HOST_PORT=3002    # par défaut : 3000
#   -> le CORS du backend autorise automatiquement ce port (cf. settings.py),
#      aucune autre modification n'est nécessaire en cas de changement.
